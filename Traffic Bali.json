      "parameters": {
        "promptType": "define",
        "text": "=Analisis teks berita lalu lintas berikut dan berikan output dalam format JSON murni.\n\nEkstrak:\n1. street_name: Nama jalan. Jika tidak ada, isi 'Unknown'.\n2. incident_date: Tanggal (YYYY-MM-DD). Asumsikan 2026.\n3. incident_type: Pilih: 'Kecelakaan', 'Kemacetan', atau 'Kebakaran'.\n\nTeks: {{ $json.text }}",
        "messages": {
          "messageValues": [
            {
              "message": "Kamu adalah asisten ekstraksi data yang hanya berkomunikasi menggunakan format JSON. Jangan memberikan penjelasan di luar JSON"
