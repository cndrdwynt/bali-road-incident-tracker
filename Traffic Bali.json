    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. Mengambil output teks dari node LLM sebelumnya\nconst rawText = $json.text;\n\n// 2. Mencari pola JSON {} di dalam teks\nconst jsonMatch = rawText.match(/\\{[\\s\\S]*\\}/);\nlet parsed = {};\n\nif (jsonMatch) {\n    try {\n        parsed = JSON.parse(jsonMatch[0]);\n    } catch (e) {\n        parsed = { street_name: \"Unknown\" };\n    }\n} else {\n    parsed = { street_name: \"Unknown\" };\n}\n\n// 3. Mengambil ID asli dari MongoDB\nconst originalId = $(\"Loop Over Items\").item.json._id;\nconst street = parsed.street_name || \"Unknown\";\n\n// 4. Logika filter\nconst isUnknown = street.toLowerCase().includes('unknown') || street === \"\";\n\n// 5. Return data bersih (Tanpa Latitude/Longitude palsu)\n// Koordinat nanti akan diambil secara otomatis oleh node HTTP Request\nreturn {\n  _id: originalId,\n  street_name: street,\n  incident_date: parsed.incident_date || \"\",\n  incident_type: parsed.incident_type || \"Lainnya\",\n  // Tambahkan dua baris ini sebagai nilai default (biar jalur False nggak error)\n  latitude: 0,\n  longitude: 0,\n  status: isUnknown ? \"ignored\" : \"processed\"\n};"
      },
